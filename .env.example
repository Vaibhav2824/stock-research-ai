# ============================================
# TradeMind MVP — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env

# --- LLM Providers ---
# Primary: Google Gemini (free tier: 15 RPM, 1M TPD)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback: Groq (free tier: 30 RPM, 14400 RPD)
GROQ_API_KEY=

# Fallback 2: OpenRouter
OPENROUTER_API_KEY=

# Future: OpenAI / Anthropic (uncomment when needed)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Data APIs ---
# NewsAPI (free tier: 100 req/day) — https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# SEC EDGAR requires a user-agent string (your name + email)
EDGAR_USER_AGENT=YourName your@email.com

# --- App Settings ---
# LLM model to use (gemini-2.0-flash is fast + free)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# Logging level
LOG_LEVEL=INFO
